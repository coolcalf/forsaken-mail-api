#!/usr/bin/env node

/**
 * Created by Hongcai Deng on 2015/12/28.
 */

'use strict';

let path = require('path');
require(path.join(__dirname, '..', 'modules/env')).loadEnv();
let app = require(path.join(__dirname, '..', 'app'));
let ioApp = require(path.join(__dirname, '..', 'modules/io'));
let debug = require('debug')('server');
let io = require('socket.io');
let http = require('http');

installProcessErrorHandlers();

/**
 * Get port from environment and store in Express.
 */

let port = normalizePort(process.env.PORT || '3000');
app.set('port', port);

/**
 * Create HTTP server.
 */

let server = http.createServer(app);
ioApp(io(server));
app.locals.startBackgroundJobs();

server.on('clientError', onClientError);


/**
 * Listen on provided port, on all network interfaces.
 */

server.listen(port);
server.on('error', onError);
server.on('listening', onListening);

/**
 * Normalize a port into a number, string, or false.
 */

function normalizePort(val) {
  let port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Event listener for HTTP server "error" event.
 */

function onError(error) {
  if (error.syscall !== 'listen') {
    throw error;
  }

  let bind = typeof port === 'string'
    ? 'Pipe ' + port
    : 'Port ' + port;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
  }
}

/**
 * Event listener for HTTP server "listening" event.
 */

function onListening() {
  let addr = server.address();
  let bind = typeof addr === 'string'
    ? 'pipe ' + addr
    : 'port ' + addr.port;
  debug('Listening on ' + bind);
}

function onClientError(error, socket) {
  console.error(formatRuntimeError('HTTP client error', error));

  if (!socket || socket.destroyed) {
    return;
  }

  socket.end('HTTP/1.1 400 Bad Request\r\nConnection: close\r\nContent-Type: application/json\r\n\r\n{"error":"Bad Request"}');
}

function installProcessErrorHandlers() {
  process.on('uncaughtException', function(error) {
    if (isIgnorableSmtpSocketError(error)) {
      console.error(formatRuntimeError('Ignoring SMTP socket error', error));
      return;
    }

    console.error(formatRuntimeError('Unhandled exception', error));
    process.exit(1);
  });

  process.on('unhandledRejection', function(reason) {
    if (isIgnorableSmtpSocketError(reason)) {
      console.error(formatRuntimeError('Ignoring SMTP socket rejection', reason));
      return;
    }

    console.error(formatRuntimeError('Unhandled rejection', reason));
    process.exit(1);
  });
}

function isIgnorableSmtpSocketError(error) {
  if (!error || typeof error !== 'object') {
    return false;
  }

  const code = typeof error.code === 'string' ? error.code : '';
  const syscall = typeof error.syscall === 'string' ? error.syscall : '';
  const message = typeof error.message === 'string' ? error.message : '';
  const stack = typeof error.stack === 'string' ? error.stack : '';
  const combined = `${message}\n${stack}`;

  if (code !== 'ECONNRESET') {
    return false;
  }

  const looksLikeMailin = combined.includes('smtp-server')
    || combined.includes('mailin')
    || combined.includes('SMTPConnection')
    || combined.includes('SMTPStream');

  if (looksLikeMailin) {
    return true;
  }

  return false;
}

function formatRuntimeError(prefix, error) {
  if (!error) {
    return `${prefix}: Unknown error`;
  }

  if (error.stack) {
    return `${prefix}: ${error.stack}`;
  }

  if (error.message) {
    return `${prefix}: ${error.message}`;
  }

  return `${prefix}: ${String(error)}`;
}
