# Forsaken Mail API: HTTP port for the web UI and API
PORT=3000

# Forsaken Mail API: SQLite database file path
FORSAKEN_MAIL_DB_PATH=./main.db

# Forsaken Mail API: comma-separated domains accepted by the MoeMail-compatible API
# Example: temp.example.com,mail.example.com
FORSAKEN_MAIL_DOMAINS=temp.example.com,test.net

# Forsaken Mail API: cleanup interval in milliseconds
FORSAKEN_MAIL_CLEANUP_INTERVAL_MS=300000

# Forsaken Mail API: optional MoeMail-compatible API key protection
# Leave empty to keep the API open.
# FORSAKEN_MAIL_API_KEY=your-api-key
# FORSAKEN_MAIL_API_KEY_HEADER=X-API-Key

# Forsaken Mail API: optional admin password for temp_mail-compatible admin endpoints
# Used by /admin/new_address and /admin/mails via the x-admin-auth header.
# Leave empty or unset to skip admin auth checks entirely.
# FORSAKEN_MAIL_ADMIN_PASSWORD=your-admin-password
