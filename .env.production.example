# Forsaken Mail API: public HTTP port exposed by the container/app
PORT=3000

# Forsaken Mail API: persistent SQLite path inside the container or host runtime
FORSAKEN_MAIL_DB_PATH=/data/main.db

# Forsaken Mail API: replace with the exact domain(s) your API is allowed to create inboxes for
# Example: temp.example.com
FORSAKEN_MAIL_DOMAINS=temp.your-domain.com

# Forsaken Mail API: background cleanup interval in milliseconds
# 60000 = 1 minute, 300000 = 5 minutes
FORSAKEN_MAIL_CLEANUP_INTERVAL_MS=300000

# Forsaken Mail API: optional MoeMail-compatible API key protection
# Leave empty to keep the API open.
# FORSAKEN_MAIL_API_KEY=your-api-key
# FORSAKEN_MAIL_API_KEY_HEADER=X-API-Key
